{
  "name": "@jslibkit/fetchflow",
  "version": "1.0.3",
  "description": "Lightweight fetch-based API handler with interceptors, auth lifecycle, and smart error handling",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "fetch",
    "api",
    "http-client",
    "interceptors",
    "typescript",
    "auth",
    "refresh-token"
  ],
  "author": "Ankit Sanpuria",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jslibkit/fetchflow.git"
  }
}